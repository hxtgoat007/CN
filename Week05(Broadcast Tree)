#include <stdio.h>
int main() {
    int n, i, j, root;
    int a[10][10];
    printf("Enter number of nodes: ");
    scanf("%d", &n);
    printf("Enter the adjacency matrix:\n");
    for(i = 0; i < n; i++) {
        for(j = 0; j < n; j++) {
            printf("Enter connecting of %d --> %d: ", i+1, j+1);
            scanf("%d", &a[i][j]);
        }
    }
    printf("Enter root node: ");
    scanf("%d", &root);
    printf("\nBroadcasting from node %d:\n", root);
    for(i = 0; i < n; i++) {
        if(a[root-1][i] == 1) {
            printf("%d -> %d\n", root, i+1);

            // Level 2 broadcast
            for(j = 0; j < n; j++) {
                if(a[i][j] == 1 && j != root-1) {
                    printf("%d -> %d\n", i+1, j+1);
                }
            }
        }
    }
    return 0;
}

