#include <stdio.h>
#include <string.h>
int main() {
    char a[50], b[100];
    int i, j = 0;
    printf("Enter the data: ");
    scanf("%s", a);
    for(i = 0; i < strlen(a); i++) {

        // If DLE occurs → add extra 'D'
        if(a[i] == 'D' && a[i+1] == 'L' && a[i+2] == 'E') {
            b[j++] = 'D';
        }
        b[j++] = a[i];
    }
    b[j] = '\0';
    printf("\nDLESTX");
    printf("%s", b);
    printf("DLEETX");
    return 0;
}

