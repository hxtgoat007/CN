#include <stdio.h>
int main() {
    int n, i;
    int s[20];
    char op;
    printf("How many stations: ");
    scanf("%d", &n);
    do {
        for(i = 0; i < n; i++) {
            printf("Enter status of station %d: ", i + 1);
            scanf("%d", &s[i]);
        }
        for(i = 0; i < n; i++) {
            if(s[i] == 1) {
                printf("Station %d is ready to transmit\n", i + 1);
            }
        }
        printf("Repeat? Press Y: ");
        scanf(" %c", &op);
    } while(op == 'Y' || op == 'y');
    return 0;
}

