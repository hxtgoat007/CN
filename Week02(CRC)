#include <stdio.h>
#include <string.h>
int main() {
    char data[50], key[20], temp[50], rem[20];
    int i, j, data_len, key_len;
    printf("Enter Data: ");
    scanf("%s", data);
    printf("Enter Key: ");
    scanf("%s", key);
    data_len = strlen(data);
    key_len = strlen(key);
    strcpy(temp, data);
    for(i = 0; i < key_len - 1; i++)
        temp[data_len + i] = '0';
    temp[data_len + key_len - 1] = '\0';
    for(i = 0; i < data_len; i++) {
        if(temp[i] == '1') {
            for(j = 0; j < key_len; j++) {
                if(temp[i + j] == key[j])
                    temp[i + j] = '0';
                else
                    temp[i + j] = '1';
            }
        }
    }
    for(i = 0; i < key_len - 1; i++)
        rem[i] = temp[data_len + i];
    rem[i] = '\0';
    printf("\nRemainder is %s\n", rem);
    printf("Final data is: %s%s\n", data, rem);

    return 0;
}

