#include <stdio.h>
#define MAX 10
#define INF 999
int main() {
    int n, i, j, start;
    int cost[10][10], dist[10], visited[10] = {0};
    printf("Enter number of nodes: ");
    scanf("%d", &n);
    printf("Enter cost matrix:\n");
    for(i = 0; i < n; i++)
        for(j = 0; j < n; j++) {
            scanf("%d", &cost[i][j]);
            if(cost[i][j] == 0)
                cost[i][j] = INF;
        }
    printf("Enter starting node: ");
    scanf("%d", &start);
    for(i = 0; i < n; i++)
        dist[i] = cost[start][i];
    dist[start] = 0;
    visited[start] = 1;
    for(i = 0; i < n-1; i++) {
        int min = INF, u;
        for(j = 0; j < n; j++)
            if(!visited[j] && dist[j] < min) {
                min = dist[j];
                u = j;
            }
        visited[u] = 1;
        for(j = 0; j < n; j++)
            if(!visited[j] && dist[j] > dist[u] + cost[u][j])
                dist[j] = dist[u] + cost[u][j];
    }
    printf("\nShortest distances from node %d:\n", start);
    for(i = 0; i < n; i++)
        printf("To %d = %d\n", i, dist[i]);
    return 0;
}

