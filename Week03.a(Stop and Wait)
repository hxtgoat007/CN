#include <stdio.h>
int main() {
    int i, frames;
    printf("Enter number of frames: ");
    scanf("%d", &frames);
    printf("No.of Frames is %d\n", frames);
    for(i = 1; i <= frames; i++) {
        if(i == frames) {
            printf("Sending frame %d\n", i);
            printf("Waiting for 1 second\n");
            printf("Sending frame %d\n", i);
            printf("Acknowledged for frame %d\n", i);
        } else {
            printf("Sending frame %d\n", i);
            printf("Acknowledged for frame %d\n", i);
        }
    }
    printf("End of stop and wait protocol\n");
    return 0;
}

